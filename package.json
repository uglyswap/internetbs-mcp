{
  "name": "internetbs-mcp",
  "version": "1.2.0",
  "description": "Complete MCP Server for Internet.bs Domain Registrar API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "internetbs-mcp": "dist/index.js"
  },
  "scripts": {
